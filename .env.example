# Copy to `.env` for local runs or independent deployment of auth-api-nest.
# Prefer a shared PostgreSQL infra endpoint with an auth-specific database/role.
# In local/dev, `DATABASE_URL` should normally target workspace root/shared PostgreSQL; repo-local PostgreSQL is only a fallback for repo-local smoke runs.
# In deployed environments, point it at the service's shared runtime PostgreSQL endpoint and auth-owned database.
NODE_ENV=development
PORT=3032
ISSUER_URL=https://auth.lafamila.xyz
DATABASE_URL=postgres://postgres:postgres@localhost:5432/teddy_auth
RUN_MIGRATIONS=false
CORS_ORIGINS=http://localhost:3032,http://localhost:3030,http://localhost:3031,http://localhost:3020
COOKIE_SECRET=change-me-cookie-secret

ADMIN_SESSION_COOKIE_NAME=tas_admin_session
ADMIN_OTP_ENCRYPTION_KEY=change-me-32-byte-minimum-admin-otp-encryption-key

SIGNUP_EMAIL_CODE_PEPPER=change-me-signup-email-code-pepper
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=auth@lafamila.xyz
